# 玩机器Bot 环境变量
# 复制此文件为 .env 并填入实际值，重启 pm2 时自动加载
# pm2 restart wanjier --update-env

# ========= 必填 =========
WANJIER_API_KEY=tp-xxxxxxxxxxxxxxxx
WANJIER_ADMIN_QQ=2711944586

# ========= 可选 (覆盖config.json) =========
# API地址
# WANJIER_API_URL=https://token-plan-cn.xiaomimimo.com/v1/chat/completions

# 模型名
# WANJIER_MODEL=mimo-v2.5-pro
# WANJIER_VISION_MODEL=mimo-v2.5-pro

# 攻击力 low/medium/high/analysis
# WANJIER_AGGRESSION=medium

# 触发概率 0~1 (低=安静)
# WANJIER_TRIGGER_PROBABILITY=0.03

# 最大输出token
# WANJIER_MAX_TOKENS=4096

# AI温度 (0.5-1.2 推荐)
# WANJIER_TEMPERATURE=0.92

# 语音概率 0~1
# WANJIER_TTS_PROBABILITY=0.2

# 真人感发送前短停顿。普通主动接话用普通区间，@/回复/命令用强触发区间
# WANJIER_HUMAN_REPLY_DELAY_ENABLED=true
# WANJIER_HUMAN_REPLY_DELAY_MIN_MS=250
# WANJIER_HUMAN_REPLY_DELAY_MAX_MS=1400
# WANJIER_HUMAN_REPLY_DELAY_FORCED_MIN_MS=120
# WANJIER_HUMAN_REPLY_DELAY_FORCED_MAX_MS=650

# RAG/上下文记忆临时覆盖
# WANJIER_ENABLE_MEMORY_RETRIEVAL=true
# WANJIER_MEMORY_TOP_K=4
# WANJIER_MEMORY_MIN_SIMILARITY=0.18
# WANJIER_MEMORY_INJECT_MAX_CHARS=700
# WANJIER_MEMORY_MAX_MESSAGES_PER_SESSION=700
# WANJIER_MEMORY_MAX_SESSIONS_IN_MEMORY=80

# 启用语音/语音输入/识图
# WANJIER_ENABLE_TTS=true
# WANJIER_ENABLE_STT=true
# WANJIER_ENABLE_VISION=true
# 本地 TTS/STT 命令默认 shell=true 兼容旧命令；生产可在 config.json 设 *_local_command_shell=false 走 argv 执行

# 群白名单(逗号分隔，留空=所有群)
# WANJIER_ENABLED_GROUPS=

# 调试日志
# WANJIER_DEBUG=1

# 每日图片清单。默认读取仓库 data/ 下同名文件；放到独立挂载盘时再改这里
# DAILY_BEAUTY_IMAGE_MANIFEST_PATH=/opt/wanjier-bot/data/daily-beauty-images.json
# BESTDORI_CARD_MANIFEST_PATH=/opt/wanjier-bot/data/bestdori-cards.json
# DAILY_PLAYER_IMAGE_MANIFEST_PATH=/opt/wanjier-bot/data/daily-player-images.json
# GENSHIN_IMAGE_MANIFEST_PATH=/opt/wanjier-bot/data/genshin-character-images.json
# 本地授权图片包扫描根目录，用 npm run daily:image:scan:write 生成 daily-beauty-images.json
# DAILY_IMAGE_PACK_ROOT=/mnt/wanjier-images/daily-beauty

# VPS 自动更新脚本开关
# WANJIER_UPDATE_SMOKE=1
# WANJIER_UPDATE_DAILY_IMAGE_AUDIT=1
# WANJIER_UPDATE_DAILY_IMAGE_TEMPLATE=1
# WANJIER_DAILY_IMAGE_AUDIT_STRICT=0
# WANJIER_IMAGE_MANIFEST_CACHE_MAX=12

# Web 管理后台 (设置后启用写操作鉴权)
# 端口在 config.json 的 web_admin_port 设置（默认0=不启用）
# 默认只监听本机 127.0.0.1；要经反代/防火墙保护后公网访问，再显式改成 0.0.0.0
# WANJIER_WEB_ADMIN_HOST=127.0.0.1
# 默认除 /api/health 外都需要 token；确实要开放只读状态页时才设为 1
# WANJIER_WEB_ADMIN_READONLY_PUBLIC=0
# 强烈建议用复杂随机字符串，例如 openssl rand -hex 32
# WANJIER_ADMIN_TOKEN=请改成你自己的token长度至少16位
