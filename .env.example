# 玩机器Bot 环境变量
# 复制此文件为 .env 并填入实际值，重启 pm2 时自动加载
# pm2 restart wanjier --update-env

# ========= 必填 =========
WANJIER_API_KEY=tp-xxxxxxxxxxxxxxxx
WANJIER_ADMIN_QQ=2711944586

# ========= 可选 (覆盖config.json) =========
# API地址
# WANJIER_API_URL=https://token-plan-cn.xiaomimimo.com/v1/chat/completions

# 模型名
# WANJIER_MODEL=mimo-v2.5-pro
# WANJIER_VISION_MODEL=mimo-v2.5-pro

# 攻击力 low/medium/high/analysis
# WANJIER_AGGRESSION=medium

# 触发概率 0~1 (低=安静)
# WANJIER_TRIGGER_PROBABILITY=0.03

# 最大输出token
# WANJIER_MAX_TOKENS=4096

# AI温度 (0.5-1.2 推荐)
# WANJIER_TEMPERATURE=0.92

# 语音概率 0~1
# WANJIER_TTS_PROBABILITY=0.2

# 启用语音/识图
# WANJIER_ENABLE_TTS=true
# WANJIER_ENABLE_VISION=true

# 群白名单(逗号分隔，留空=所有群)
# WANJIER_ENABLED_GROUPS=

# 调试日志
# WANJIER_DEBUG=1
